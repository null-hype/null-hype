{
  "mcpServers": {
    "container-use": {
      "type": "stdio",
      "command": "container-use",
      "args": ["mcp"]
    },
    "linear": {
      "type": "http",
      "url": "https://mcp.linear.app/mcp",
      "headers": {
        "Authorization": "Bearer ${LINEAR_API_KEY}"
      }
    }
  }
}
